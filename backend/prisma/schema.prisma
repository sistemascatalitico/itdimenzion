generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SUPERVISOR
  USER
}

enum Status {
  ACTIVE
  INACTIVE
}

enum DocumentType {
  CEDULA
  TARJETA_IDENTIDAD
  CEDULA_EXTRANJERIA
  NIT
  RUT
  PASSPORT
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  MAINTENANCE
  RETIRED
}

enum AssetCondition {
  NEW
  GOOD
  FAIR
  POOR
}

model Company {
  id          Int           @id @default(autoincrement())
  name        String        @unique
  nit         String        @unique // NIT as primary business identifier
  description String?       @db.Text
  email       String?
  phone       String?
  address     String?       @db.Text
  cityId      Int?
  stateId     Int?
  countryId   Int?
  website     String?
  logo        String?
  status      Status        @default(ACTIVE)
  code        String        @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  createdBy   String?
  updatedBy   String?
  
  // Geographic relationships
  city         City?         @relation(fields: [cityId], references: [id])
  state        State?        @relation(fields: [stateId], references: [id])
  country      Country?      @relation(fields: [countryId], references: [id])
  
  headquarters      Headquarters[]
  users            User[]
  assets           Asset[]
  companyProcesses CompanyProcess[]
  companyJobTitles CompanyJobTitle[]
  
  @@map("companies")
}

model Headquarters {
  id          Int       @id @default(autoincrement())
  name        String
  description String?   @db.Text
  address     String?   @db.Text
  cityId      Int?
  stateId     Int?
  countryId   Int?
  phone       String?
  email       String?
  status      Status    @default(ACTIVE)
  code        String    @unique
  companyId   Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  
  // Geographic relationships
  city         City?     @relation(fields: [cityId], references: [id])
  state        State?    @relation(fields: [stateId], references: [id])
  country      Country?  @relation(fields: [countryId], references: [id])
  
  company     Company   @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users       User[]
  assets      Asset[]
  
  @@unique([name, companyId]) // Same headquarter name can exist in different companies
  @@map("headquarters")
}

model User {
  documentNumber        String       @id // Document number as primary key (cedula)
  documentType          DocumentType
  username              String       @unique // Unique username for login
  email                 String       @unique // Unique email for login
  contactEmail          String?
  password              String
  firstName             String
  lastName              String
  phone                 String?
  // Address and residence fields (flat strings, single association semantics)
  addressLine1          String?      @db.Text
  addressLine2          String?      @db.Text
  residenceCountry      String?      // ISO-2 code (e.g., CO, US)
  residenceState        String?      // Region/state code or name (project-defined)
  residenceCity         String?      // City name
  commentary            String?      @db.Text
  userGroupId           Int?
  role                  UserRole     @default(USER)
  status                Status       @default(ACTIVE)
  lastLogin             DateTime?
  loginAttempts         Int          @default(0)
  lockedUntil           DateTime?
  resetToken            String?
  resetTokenExpiry      DateTime?
  companyId             Int?         // User belongs to one company only
  headquartersId        Int?         // User assigned to headquarters
  processId             Int?         // Process is global to company
  jobTitleId            Int?         // JobTitle belongs to user
  emailVerified         Boolean      @default(false)
  emailVerificationToken String?     @unique
  passwordResetToken     String?     @unique
  passwordResetExpires   DateTime?
  twoFactorEnabled       Boolean      @default(false)
  twoFactorSecret        String?
  profilePicture         String?
  isDeletionProtected    Boolean      @default(false) // Prevents user from being deleted/disabled
  createdAt             DateTime     @default(now())
  updatedAt             DateTime     @updatedAt
  createdBy             String?      // Document number of creator
  updatedBy             String?      // Document number of updater
  
  company               Company?     @relation(fields: [companyId], references: [id])
  headquarters          Headquarters? @relation(fields: [headquartersId], references: [id])
  process               Process?     @relation(fields: [processId], references: [id])
  jobTitle              JobTitle?    @relation(fields: [jobTitleId], references: [id])
  userGroup             UserGroup?   @relation(fields: [userGroupId], references: [id])
  creator               User?        @relation("UserCreatedBy", fields: [createdBy], references: [documentNumber])
  createdUsers          User[]       @relation("UserCreatedBy")
  refreshTokens         RefreshToken[]
  loginLogs             LoginLog[]
  userGroupMembers      UserGroupMember[]
  assignedAssets        Asset[]      @relation("AssetAssignedTo")
  createdAssets         Asset[]      @relation("AssetCreatedBy")
  updatedAssets         Asset[]      @relation("AssetUpdatedBy")
  
  @@index([email])
  @@index([username])
  @@index([status])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String   // References User.documentNumber
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  user      User     @relation(fields: [userId], references: [documentNumber], onDelete: Cascade)
  
  @@map("refresh_tokens")
}

model LoginLog {
  id          String   @id @default(cuid())
  userId      String   // References User.documentNumber
  ipAddress   String
  userAgent   String?
  success     Boolean
  failureReason String?
  timestamp   DateTime @default(now())
  
  user        User     @relation(fields: [userId], references: [documentNumber], onDelete: Cascade)
  
  @@index([userId])
  @@index([timestamp])
  @@map("login_logs")
}

model Process {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?   @db.Text
  status      Status    @default(ACTIVE)
  code        String    @unique
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  
  users            User[]
  jobTitles        JobTitle[]
  companyProcesses CompanyProcess[]
  
  @@map("processes")
}

model JobTitle {
  id               Int       @id @default(autoincrement())
  name             String    @unique
  description      String?   @db.Text
  status           Status    @default(ACTIVE)
  code             String    @unique
  processId        Int
  processManager   Boolean   @default(false)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  createdBy        String?
  updatedBy        String?
  
  process          Process   @relation(fields: [processId], references: [id], onDelete: Cascade)
  users            User[]
  companyJobTitles CompanyJobTitle[]
  
  @@map("job_titles")
}

// User Groups System
model UserGroup {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?   @db.Text
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  
  members     UserGroupMember[]
  users       User[]
  
  @@map("user_groups")
}

model UserGroupMember {
  id          Int       @id @default(autoincrement())
  userId      String    // References User.documentNumber
  userGroupId Int
  createdAt   DateTime  @default(now())
  createdBy   String?   // References User.documentNumber
  
  user        User      @relation(fields: [userId], references: [documentNumber], onDelete: Cascade)
  userGroup   UserGroup @relation(fields: [userGroupId], references: [id], onDelete: Cascade)
  
  @@unique([userId, userGroupId])
  @@map("user_group_members")
}

// Asset Management System
model AssetCategory {
  id           Int       @id @default(autoincrement())
  name         String    @unique
  label        String    @unique
  description  String?   @db.Text
  status       Status    @default(ACTIVE)
  isPersistent Boolean   @default(false)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  createdBy    String?
  updatedBy    String?
  
  assets       Asset[]
  assetGroups  AssetGroup[]
  
  @@map("asset_categories")
}

model AssetGroup {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?   @db.Text
  status      Status    @default(ACTIVE)
  isSystem    Boolean   @default(false)
  categoryId  Int
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  
  category    AssetCategory @relation(fields: [categoryId], references: [id])
  assets      Asset[]
  
  @@map("asset_groups")
}

model AssetManufacturer {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?   @db.Text
  website     String?
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  
  models      AssetModel[]
  
  @@map("asset_manufacturers")
}

model AssetModel {
  id             Int       @id @default(autoincrement())
  name           String
  description    String?   @db.Text
  manufacturerId Int
  status         Status    @default(ACTIVE)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  createdBy      String?
  updatedBy      String?
  
  manufacturer   AssetManufacturer @relation(fields: [manufacturerId], references: [id])
  assets         Asset[]
  
  @@unique([name, manufacturerId])
  @@map("asset_models")
}

model Asset {
  id                  Int           @id @default(autoincrement())
  name                String
  description         String?       @db.Text
  serialNumber        String?
  status              AssetStatus   @default(ACTIVE)
  condition           AssetCondition @default(NEW)
  purchaseDate        DateTime?
  warrantyExpiration  DateTime?
  notes               String?       @db.Text
  categoryId          Int
  modelId             Int
  groupId             Int
  companyId           Int
  headquartersId      Int
  assignedUserId      String?       // References User.documentNumber
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  createdById         String        // References User.documentNumber
  updatedById         String?       // References User.documentNumber
  
  category            AssetCategory @relation(fields: [categoryId], references: [id])
  model               AssetModel    @relation(fields: [modelId], references: [id])
  group               AssetGroup    @relation(fields: [groupId], references: [id])
  company             Company       @relation(fields: [companyId], references: [id])
  headquarters        Headquarters  @relation(fields: [headquartersId], references: [id])
  assignedUser        User?         @relation("AssetAssignedTo", fields: [assignedUserId], references: [documentNumber])
  createdBy           User          @relation("AssetCreatedBy", fields: [createdById], references: [documentNumber])
  updatedBy           User?         @relation("AssetUpdatedBy", fields: [updatedById], references: [documentNumber])
  
  @@map("assets")
}

// Many-to-Many Relationship Tables
model CompanyProcess {
  id        Int      @id @default(autoincrement())
  companyId Int
  processId Int
  createdAt DateTime @default(now())
  createdBy String?
  
  company   Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  process   Process  @relation(fields: [processId], references: [id], onDelete: Cascade)
  
  @@unique([companyId, processId])
  @@map("company_processes")
}

model CompanyJobTitle {
  id         Int      @id @default(autoincrement())
  companyId  Int
  jobTitleId Int
  createdAt  DateTime @default(now())
  createdBy  String?
  
  company    Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  jobTitle   JobTitle @relation(fields: [jobTitleId], references: [id], onDelete: Cascade)
  
  @@unique([companyId, jobTitleId])
  @@map("company_job_titles")
}

// Geography Models for Colombia and USA
model Country {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  code        String    @unique // CO, US
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  states      State[]
  companies   Company[]
  headquarters Headquarters[]
  
  @@map("countries")
}

model State {
  id          Int       @id @default(autoincrement())
  name        String
  code        String    // ANT, CAL, NY, CA, etc.
  countryId   Int
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  country     Country   @relation(fields: [countryId], references: [id])
  cities      City[]
  companies   Company[]
  headquarters Headquarters[]
  
  @@unique([name, countryId])
  @@map("states")
}

model City {
  id          Int       @id @default(autoincrement())
  name        String
  stateId     Int
  status      Status    @default(ACTIVE)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  
  state       State     @relation(fields: [stateId], references: [id])
  companies   Company[]
  headquarters Headquarters[]
  
  @@unique([name, stateId])
  @@map("cities")
}

model AuditLog {
  id          String   @id @default(cuid())
  userId      String?
  action      String
  entityType  String
  entityId    String?
  oldValues   Json?
  newValues   Json?
  ipAddress   String?
  userAgent   String?
  timestamp   DateTime @default(now())
  
  @@index([userId])
  @@index([timestamp])
  @@index([entityType])
  @@map("audit_logs")
}