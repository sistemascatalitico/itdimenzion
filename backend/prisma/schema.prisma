  passwordResetToken                                 String?              @unique
  passwordResetExpires                               DateTime?
  twoFactorEnabled                                   Boolean              @default(false)
  twoFactorSecret                                    String?
  profilePicture                                     String?
  isDeletionProtected                                Boolean              @default(false)
  createdAt                                          DateTime             @default(now())
  updatedAt                                          DateTime
  createdBy                                          String?
  updatedBy                                          String?
  AssetAssignment                                    AssetAssignment[]
  asset_documents_asset_documents_deliveredByTousers AssetDocument[]      @relation("asset_documents_deliveredByTousers")
  asset_documents_asset_documents_fromUserIdTousers  AssetDocument[]      @relation("asset_documents_fromUserIdTousers")
  asset_documents_asset_documents_preparedByTousers  AssetDocument[]      @relation("asset_documents_preparedByTousers")
  asset_documents_asset_documents_receivedByTousers  AssetDocument[]      @relation("asset_documents_receivedByTousers")
  asset_documents_asset_documents_toUserIdTousers    AssetDocument[]      @relation("asset_documents_toUserIdTousers")
  AssetLicense                                       AssetLicense[]
  AssetStatusHistory                                 AssetStatusHistory[]
  AssetChangeHistory                                 AssetChangeHistory[] @relation("AssetChangeHistory")
  assets_assets_assignedUserIdTousers                Asset[]              @relation("assets_assignedUserIdTousers")
  assets_assets_createdByIdTousers                   Asset[]              @relation("assets_createdByIdTousers")
  assets_assets_updatedByIdTousers                   Asset[]              @relation("assets_updatedByIdTousers")
  assets_assets_deletedByTousers                     Asset[]              @relation("assets_deletedByTousers")
  assets_assets_restoredByTousers                    Asset[]              @relation("assets_restoredByTousers")
  FormSubmission                                     FormSubmission[]
  forms_forms_createdByTousers                       Form[]               @relation("forms_createdByTousers")
  forms_forms_deletedByTousers                       Form[]               @relation("forms_deletedByTousers")
  LoginLog                                           LoginLog[]
  PasswordHistory                                    PasswordHistory[]
  RefreshToken                                       RefreshToken[]
  suppliers_suppliers_createdByTousers               Supplier[]           @relation("suppliers_createdByTousers")
  suppliers_suppliers_updatedByTousers               Supplier[]           @relation("suppliers_updatedByTousers")
  UserGroupMember                                    UserGroupMember[]
  Company                                            Company?             @relation(fields: [companyId], references: [id])
  User                                               User?                @relation("usersTousers", fields: [createdBy], references: [documentNumber])
  other_users                                        User[]               @relation("usersTousers")
  Headquarters                                       Headquarters?        @relation(fields: [headquartersId], references: [id])
  JobTitle                                           JobTitle?            @relation(fields: [jobTitleId], references: [id])
  Process                                            Process?             @relation(fields: [processId], references: [id])
  UserGroup                                          UserGroup?           @relation(fields: [userGroupId], references: [id])

  @@index([companyId], map: "users_companyId_fkey")
  @@index([createdBy], map: "users_createdBy_fkey")
  @@index([email])
  @@index([headquartersId], map: "users_headquartersId_fkey")
  @@index([jobTitleId], map: "users_jobTitleId_fkey")
  @@index([processId], map: "users_processId_fkey")
  @@index([status])
  @@index([userGroupId], map: "users_userGroupId_fkey")
  @@index([username])
  @@map("users")
}

