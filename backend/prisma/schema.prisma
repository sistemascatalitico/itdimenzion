generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model AssetAssignmentDoc {
  id              Int               @id @default(autoincrement())
  companyId       Int
  docNumber       String
  pdfUrl          String?
  signedByUserId  String?
  signedAt        DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  Company         Company           @relation(fields: [companyId], references: [id])
  AssetAssignment AssetAssignment[]

  @@unique([companyId, docNumber])
  @@index([companyId])
  @@map("asset_assignment_docs")
}

model AssetAssignment {
  id                  Int                              @id @default(autoincrement())
  assetId             Int
  assignmentType      asset_assignments_assignmentType
  assignedToUserId    String?
  assignedToCompanyId Int?
  assignedToHqId      Int?
  assignmentDocId     Int?
  startDate           DateTime                         @default(now())
  endDate             DateTime?
  status              asset_assignments_status         @default(ACTIVE)
  commentary          String?                          @db.Text
  createdAt           DateTime                         @default(now())
  updatedAt           DateTime
  Asset               Asset                            @relation(fields: [assetId], references: [id], onDelete: Cascade)
  Company             Company?                         @relation(fields: [assignedToCompanyId], references: [id])
  Headquarters        Headquarters?                    @relation(fields: [assignedToHqId], references: [id])
  User                User?                            @relation(fields: [assignedToUserId], references: [documentNumber])
  AssetAssignmentDoc  AssetAssignmentDoc?              @relation(fields: [assignmentDocId], references: [id])

  @@index([assetId, status])
  @@index([assignedToCompanyId], map: "asset_assignments_assignedToCompanyId_fkey")
  @@index([assignedToHqId], map: "asset_assignments_assignedToHqId_fkey")
  @@index([assignedToUserId])
  @@index([assignmentDocId], map: "asset_assignments_assignmentDocId_fkey")
  @@map("asset_assignments")
}

model AssetCategory {
  id                   Int                     @id @default(autoincrement())
  name                 String                  @unique
  label                String                  @unique
  description          String?                 @db.Text
  status               asset_categories_status @default(ACTIVE)
  isPersistent         Boolean                 @default(false)
  createdAt            DateTime                @default(now())
  updatedAt            DateTime
  createdBy            String?
  updatedBy            String?
  AssetCustomSchema    AssetCustomSchema[]
  AssetGroup           AssetGroup[]
  AssetType            AssetType[]
  Asset                Asset[]
  Form                 Form[]
  ManufacturerCategory ManufacturerCategory[]

  @@map("asset_categories")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model AssetComponent {
  id                                            Int                             @id @default(autoincrement())
  parentAssetId                                 Int
  childAssetId                                  Int
  relationRole                                  String?
  connectionType                                asset_components_connectionType @default(COMPONENT)
  isMandatory                                   Boolean                         @default(false)
  isPhysical                                    Boolean                         @default(true)
  notes                                         String?                         @db.Text
  quantity                                      Int                             @default(1)
  positionIndex                                 Int?
  status                                        asset_components_status         @default(ACTIVE)
  createdAt                                     DateTime                        @default(now())
  updatedAt                                     DateTime?                       @default(now()) @db.Timestamp(0)
  removedAt                                     DateTime?
  createdById                                   String?
  removedById                                   String?
  assets_asset_components_childAssetIdToassets  Asset                           @relation("asset_components_childAssetIdToassets", fields: [childAssetId], references: [id], onDelete: Cascade)
  assets_asset_components_parentAssetIdToassets Asset                           @relation("asset_components_parentAssetIdToassets", fields: [parentAssetId], references: [id], onDelete: Cascade)

  @@unique([childAssetId, status])
  @@index([childAssetId])
  @@index([parentAssetId])
  @@index([isMandatory], map: "idx_components_mandatory")
  @@index([parentAssetId, connectionType], map: "idx_components_type")
  @@index([updatedAt], map: "idx_components_updated")
  @@map("asset_components")
}

model AssetCustomSchema {
  id               Int                         @id @default(autoincrement())
  name             String
  scope            asset_custom_schemas_scope
  categoryId       Int?
  groupId          Int?
  typeId           Int?
  schemaJson       Json
  status           asset_custom_schemas_status @default(ACTIVE)
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime
  AssetCategory    AssetCategory?              @relation(fields: [categoryId], references: [id])
  AssetGroup       AssetGroup?                 @relation(fields: [groupId], references: [id])
  AssetType        AssetType?                  @relation(fields: [typeId], references: [id])
  AssetCustomValue AssetCustomValue[]

  @@index([categoryId], map: "asset_custom_schemas_categoryId_fkey")
  @@index([groupId], map: "asset_custom_schemas_groupId_fkey")
  @@index([typeId], map: "asset_custom_schemas_typeId_fkey")
  @@map("asset_custom_schemas")
}

model AssetCustomValue {
  id                Int               @id @default(autoincrement())
  assetId           Int
  schemaId          Int
  valuesJson        Json
  createdAt         DateTime          @default(now())
  updatedAt         DateTime
  Asset             Asset             @relation(fields: [assetId], references: [id], onDelete: Cascade)
  AssetCustomSchema AssetCustomSchema @relation(fields: [schemaId], references: [id], onDelete: Cascade)

  @@unique([assetId, schemaId])
  @@index([schemaId], map: "asset_custom_values_schemaId_fkey")
  @@map("asset_custom_values")
}

model AssetDocument {
  id                                                            Int                     @id @default(autoincrement())
  documentNumber                                                String?                 @db.VarChar(50)
  documentTypeId                                                Int?
  status                                                        asset_documents_status  @default(DRAFT)
  formId                                                        Int?
  formData                                                      Json?
  formVersion                                                   Int?
  fromUserId                                                    String?
  fromCompanyId                                                 Int?
  fromHeadquartersId                                            Int?
  fromLocation                                                  String?                 @db.VarChar(500)
  toUserId                                                      String?
  toCompanyId                                                   Int?
  toHeadquartersId                                              Int?
  toLocation                                                    String?                 @db.VarChar(500)
  assetId                                                       Int?
  docType                                                       asset_documents_docType
  title                                                         String
  fileUrl                                                       String                  @db.Text
  externalRef                                                   String?
  supplier                                                      String?
  amount                                                        Decimal?                @db.Decimal(16, 2)
  documentDate                                                  DateTime?
  effectiveDate                                                 DateTime?               @db.DateTime(0)
  expirationDate                                                DateTime?               @db.DateTime(0)
  preparedBy                                                    String?
  preparedDate                                                  DateTime?               @db.DateTime(0)
  deliveredBy                                                   String?
  deliveredDate                                                 DateTime?               @db.DateTime(0)
  receivedBy                                                    String?
  receivedDate                                                  DateTime?               @db.DateTime(0)
  pdfUrl                                                        String?                 @db.Text
  signatureUrl                                                  String?                 @db.Text
  photos                                                        Json?
  deliveryNotes                                                 String?                 @db.Text
  receptionNotes                                                String?                 @db.Text
  observations                                                  String?                 @db.Text
  commentary                                                    String?                 @db.Text
  createdAt                                                     DateTime                @default(now())
  updatedAt                                                     DateTime
  createdBy                                                     String?
  documentRef                                                   String?
  fileSize                                                      Int?
  isActive                                                      Boolean                 @default(true)
  supersededBy                                                  Int?
  mimeType                                                      String?
  relatedCompanyId                                              Int?
  relatedDocumentId                                             Int?
  relatedUserId                                                 String?
  updatedBy                                                     String?
  Asset                                                         Asset?                  @relation(fields: [assetId], references: [id], onDelete: Cascade)
  users_asset_documents_deliveredByTousers                      User?                   @relation("asset_documents_deliveredByTousers", fields: [deliveredBy], references: [documentNumber], onUpdate: NoAction, map: "fk_asset_documents_delivered_by")
  DocumentType                                                  DocumentType?           @relation(fields: [documentTypeId], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_asset_documents_document_type")
  Form                                                          Form?                   @relation(fields: [formId], references: [id], onUpdate: NoAction, map: "fk_asset_documents_form")
  companies_asset_documents_fromCompanyIdTocompanies            Company?                @relation("asset_documents_fromCompanyIdTocompanies", fields: [fromCompanyId], references: [id], onUpdate: NoAction, map: "fk_asset_documents_from_company")
  headquarters_asset_documents_fromHeadquartersIdToheadquarters Headquarters?           @relation("asset_documents_fromHeadquartersIdToheadquarters", fields: [fromHeadquartersId], references: [id], onUpdate: NoAction, map: "fk_asset_documents_from_hq")
  users_asset_documents_fromUserIdTousers                       User?                   @relation("asset_documents_fromUserIdTousers", fields: [fromUserId], references: [documentNumber], onUpdate: NoAction, map: "fk_asset_documents_from_user")
  users_asset_documents_preparedByTousers                       User?                   @relation("asset_documents_preparedByTousers", fields: [preparedBy], references: [documentNumber], onUpdate: NoAction, map: "fk_asset_documents_prepared_by")
  users_asset_documents_receivedByTousers                       User?                   @relation("asset_documents_receivedByTousers", fields: [receivedBy], references: [documentNumber], onUpdate: NoAction, map: "fk_asset_documents_received_by")
  AssetDocument                                                 AssetDocument?          @relation("asset_documentsToasset_documents", fields: [supersededBy], references: [id], onUpdate: NoAction, map: "fk_asset_documents_superseded_by")
  other_asset_documents                                         AssetDocument[]         @relation("asset_documentsToasset_documents")
  companies_asset_documents_toCompanyIdTocompanies              Company?                @relation("asset_documents_toCompanyIdTocompanies", fields: [toCompanyId], references: [id], onUpdate: NoAction, map: "fk_asset_documents_to_company")
  headquarters_asset_documents_toHeadquartersIdToheadquarters   Headquarters?           @relation("asset_documents_toHeadquartersIdToheadquarters", fields: [toHeadquartersId], references: [id], onUpdate: NoAction, map: "fk_asset_documents_to_hq")
  users_asset_documents_toUserIdTousers                         User?                   @relation("asset_documents_toUserIdTousers", fields: [toUserId], references: [documentNumber], onUpdate: NoAction, map: "fk_asset_documents_to_user")
  AssetStatusHistory                                            AssetStatusHistory[]
  DocumentAsset                                                 DocumentAsset[]

  @@index([assetId, docType])
  @@index([assetId, isActive])
  @@index([relatedDocumentId])
  @@index([deliveredBy], map: "fk_asset_documents_delivered_by")
  @@index([fromCompanyId], map: "fk_asset_documents_from_company")
  @@index([fromHeadquartersId], map: "fk_asset_documents_from_hq")
  @@index([fromUserId], map: "fk_asset_documents_from_user")
  @@index([preparedBy], map: "fk_asset_documents_prepared_by")
  @@index([receivedBy], map: "fk_asset_documents_received_by")
  @@index([supersededBy], map: "fk_asset_documents_superseded_by")
  @@index([toHeadquartersId], map: "fk_asset_documents_to_hq")
  @@index([isActive, status], map: "idx_asset_documents_active_status")
  @@index([toCompanyId, documentDate], map: "idx_asset_documents_company_date")
  @@index([createdAt], map: "idx_asset_documents_created_at")
  @@index([formId], map: "idx_asset_documents_form")
  @@index([documentNumber], map: "idx_asset_documents_number")
  @@index([documentTypeId, status], map: "idx_asset_documents_type_status")
  @@index([toUserId, isActive], map: "idx_asset_documents_user_active")
  @@map("asset_documents")
}

model AssetFieldValue {
  id             Int            @id @default(autoincrement())
  assetId        Int
  fieldId        Int
  valueText      String?
  valueNumber    Float?
  valueDecimal   Decimal?       @db.Decimal(20, 6)
  valueBoolean   Boolean?
  valueDate      DateTime?
  valueJson      Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime
  Asset          Asset          @relation(fields: [assetId], references: [id], onDelete: Cascade)
  CustomFieldDef CustomFieldDef @relation(fields: [fieldId], references: [id], onDelete: Cascade)

  @@unique([assetId, fieldId])
  @@index([fieldId])
  @@map("asset_field_values")
}

model AssetGroup {
  id                Int                 @id @default(autoincrement())
  name              String              @unique
  description       String?             @db.Text
  status            asset_groups_status @default(ACTIVE)
  isSystem          Boolean             @default(false)
  categoryId        Int
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  createdBy         String?
  updatedBy         String?
  label             String?
  AssetCustomSchema AssetCustomSchema[]
  AssetCategory     AssetCategory       @relation(fields: [categoryId], references: [id])
  AssetType         AssetType[]
  Asset             Asset[]
  Form              Form[]

  @@index([categoryId], map: "asset_groups_categoryId_fkey")
  @@map("asset_groups")
}

model AssetImage {
  id        Int                    @id @default(autoincrement())
  assetId   Int
  imageUrl  String                 @db.Text
  imageType asset_images_imageType @default(PHOTO)
  title     String?
  order     Int                    @default(0)
  createdAt DateTime               @default(now())
  createdBy String?
  Asset     Asset                  @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("asset_images")
}

model AssetLicense {
  id               Int                   @id @default(autoincrement())
  assetId          Int
  licenseId        Int
  assignedAt       DateTime              @default(now())
  revokedAt        DateTime?
  status           asset_licenses_status @default(ACTIVE)
  assignedToUserId String?
  Asset            Asset                 @relation(fields: [assetId], references: [id], onDelete: Cascade)
  User             User?                 @relation(fields: [assignedToUserId], references: [documentNumber])
  SoftwareLicense  SoftwareLicense       @relation(fields: [licenseId], references: [id], onDelete: Cascade)

  @@unique([assetId, licenseId, status])
  @@index([assignedToUserId], map: "asset_licenses_assignedToUserId_fkey")
  @@index([licenseId], map: "asset_licenses_licenseId_fkey")
  @@map("asset_licenses")
}

model AssetManufacturer {
  id                   Int                        @id @default(autoincrement())
  name                 String                     @unique
  description          String?                    @db.Text
  website              String?
  status               asset_manufacturers_status @default(ACTIVE)
  createdAt            DateTime                   @default(now())
  updatedAt            DateTime
  createdBy            String?
  updatedBy            String?
  logo                 String?                    @db.Text
  AssetModel           AssetModel[]
  ManufacturerCategory ManufacturerCategory[]

  @@map("asset_manufacturers")
}

model AssetModelDocument {
  id         Int                           @id @default(autoincrement())
  modelId    Int
  docType    asset_model_documents_docType
  title      String
  fileUrl    String                        @db.Text
  fileSize   Int?
  mimeType   String?
  createdAt  DateTime                      @default(now())
  createdBy  String?
  AssetModel AssetModel                    @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("asset_model_documents")
}

model AssetModelImage {
  id         Int                          @id @default(autoincrement())
  modelId    Int
  imageUrl   String                       @db.Text
  imageType  asset_model_images_imageType @default(PHOTO)
  title      String?
  order      Int                          @default(0)
  createdAt  DateTime                     @default(now())
  createdBy  String?
  AssetModel AssetModel                   @relation(fields: [modelId], references: [id], onDelete: Cascade)

  @@index([modelId])
  @@map("asset_model_images")
}

model AssetModel {
  id                 Int                  @id @default(autoincrement())
  name               String
  description        String?              @db.Text
  manufacturerId     Int
  status             asset_models_status  @default(ACTIVE)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime
  createdBy          String?
  updatedBy          String?
  partNumber         String?
  specsJson          Json?
  typeId             Int?
  referenceImage     String?              @db.Text
  AssetModelDocument AssetModelDocument[]
  AssetModelImage    AssetModelImage[]
  AssetManufacturer  AssetManufacturer    @relation(fields: [manufacturerId], references: [id])
  AssetType          AssetType?           @relation(fields: [typeId], references: [id])
  Asset              Asset[]

  @@unique([name, manufacturerId])
  @@index([manufacturerId], map: "asset_models_manufacturerId_fkey")
  @@index([typeId], map: "asset_models_typeId_fkey")
  @@map("asset_models")
}

model AssetStatusHistory {
  id                         Int                                  @id @default(autoincrement())
  assetId                    Int
  previousStatus             asset_status_history_previousStatus?
  newStatus                  asset_status_history_newStatus
  documentId                 Int?
  changeReason               String?                              @db.Text
  changedBy                  String
  changedAt                  DateTime?                            @default(now()) @db.Timestamp(0)
  rollbackId                 Int?
  Asset                      Asset                                @relation(fields: [assetId], references: [id], onDelete: Cascade, onUpdate: NoAction, map: "asset_status_history_ibfk_1")
  AssetDocument              AssetDocument?                       @relation(fields: [documentId], references: [id], onUpdate: NoAction, map: "asset_status_history_ibfk_2")
  User                       User                                 @relation(fields: [changedBy], references: [documentNumber], onUpdate: NoAction, map: "asset_status_history_ibfk_3")
  AssetStatusHistory         AssetStatusHistory?                  @relation("asset_status_historyToasset_status_history", fields: [rollbackId], references: [id], onUpdate: NoAction, map: "asset_status_history_ibfk_4")
  other_asset_status_history AssetStatusHistory[]                 @relation("asset_status_historyToasset_status_history")

  @@index([assetId, changedAt], map: "idx_asset_status_history_asset_date")
  @@index([documentId], map: "idx_asset_status_history_document")
  @@index([newStatus], map: "idx_asset_status_history_new_status")
  @@index([changedBy], map: "idx_asset_status_history_user")
  @@index([rollbackId], map: "rollbackId")
  @@map("asset_status_history")
}

model AssetChangeHistory {
  id           Int      @id @default(autoincrement())
  assetId      Int
  fieldName    String
  oldValue     String?  @db.Text
  newValue     String?  @db.Text
  changedBy    String
  changedAt    DateTime @default(now())
  changeReason String?  @db.Text
  ipAddress    String?
  userAgent    String?

  Asset Asset @relation("AssetChangeHistory", fields: [assetId], references: [id], onDelete: Cascade)
  User  User  @relation("AssetChangeHistory", fields: [changedBy], references: [documentNumber])

  @@index([assetId, changedAt])
  @@index([changedBy])
  @@map("asset_change_history")
}

model AssetTransfer {
  id                                                            Int                          @id @default(autoincrement())
  assetId                                                       Int
  transferType                                                  asset_transfers_transferType
  fromCompanyId                                                 Int?
  toCompanyId                                                   Int?
  fromHeadquartersId                                            Int?
  toHeadquartersId                                              Int?
  providerId                                                    Int?
  startDate                                                     DateTime
  expectedReturnDate                                            DateTime?
  endDate                                                       DateTime?
  status                                                        asset_transfers_status       @default(DRAFT)
  docNumber                                                     String?
  notes                                                         String?                      @db.Text
  createdAt                                                     DateTime                     @default(now())
  updatedAt                                                     DateTime
  Asset                                                         Asset                        @relation(fields: [assetId], references: [id], onDelete: Cascade)
  companies_asset_transfers_fromCompanyIdTocompanies            Company?                     @relation("asset_transfers_fromCompanyIdTocompanies", fields: [fromCompanyId], references: [id])
  headquarters_asset_transfers_fromHeadquartersIdToheadquarters Headquarters?                @relation("asset_transfers_fromHeadquartersIdToheadquarters", fields: [fromHeadquartersId], references: [id])
  IspProvider                                                   IspProvider?                 @relation(fields: [providerId], references: [id])
  companies_asset_transfers_toCompanyIdTocompanies              Company?                     @relation("asset_transfers_toCompanyIdTocompanies", fields: [toCompanyId], references: [id])
  headquarters_asset_transfers_toHeadquartersIdToheadquarters   Headquarters?                @relation("asset_transfers_toHeadquartersIdToheadquarters", fields: [toHeadquartersId], references: [id])

  @@index([assetId, transferType, status])
  @@index([fromCompanyId])
  @@index([fromHeadquartersId])
  @@index([providerId], map: "asset_transfers_providerId_fkey")
  @@index([toCompanyId])
  @@index([toHeadquartersId])
  @@map("asset_transfers")
}

model AssetType {
  id                Int                 @id @default(autoincrement())
  groupId           Int
  name              String
  status            asset_types_status  @default(ACTIVE)
  allowsConnections Boolean             @default(false)
  connectionConfig  Json?
  createdAt         DateTime            @default(now())
  updatedAt         DateTime
  categoryId        Int
  description       String?             @db.Text
  label             String?
  formTemplateId    Int?                @unique
  form_template_id  Int?                @unique(map: "idx_asset_type_form_unique")
  AssetCustomSchema AssetCustomSchema[]
  AssetModel        AssetModel[]
  AssetCategory     AssetCategory       @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  AssetGroup        AssetGroup          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  Form              Form?               @relation(fields: [form_template_id], references: [id], onUpdate: NoAction, map: "fk_asset_type_form")
  Asset             Asset[]

  @@unique([groupId, name])
  @@index([categoryId])
  @@index([formTemplateId])
  @@index([allowsConnections], map: "idx_asset_types_allows_connections")
  @@index([form_template_id], map: "idx_asset_types_form")
  @@map("asset_types")
}

model Asset {
  id                                                      Int                  @id @default(autoincrement())
  name                                                    String
  description                                             String?              @db.Text
  serialNumber                                            String?              @unique
  status                                                  assets_status        @default(ACTIVE)
  condition                                               assets_condition     @default(NEW)
  purchaseDate                                            DateTime?
  warrantyExpiration                                      DateTime?
  notes                                                   String?              @db.Text
  categoryId                                              Int
  modelId                                                 Int?
  groupId                                                 Int
  companyId                                               Int?
  headquartersId                                          Int?
  assignedUserId                                          String?
  createdAt                                               DateTime             @default(now())
  updatedAt                                               DateTime
  createdById                                             String
  updatedById                                             String?
  isDeleted                                               Boolean              @default(false)
  deletedAt                                               DateTime?            @db.Timestamp(0)
  deletedBy                                               String?
  deletionReason                                          String?              @db.Text
  restoredAt                                              DateTime?            @db.Timestamp(0)
  restoredBy                                              String?
  restorationReason                                       String?              @db.Text
  assetCode                                               String?              @unique
  commentary                                              String?              @db.Text
  location                                                String?
  purchaseValue                                           Decimal?             @db.Decimal(16, 2)
  purchasedByCompanyId                                    Int?
  typeId                                                  Int?
  costCenter                                              String?
  formData                                                Json?
  formId                                                  Int?
  formVersion                                             Int?
  invoiceNumber                                           String?
  processId                                               Int?
  purchaseCompanyId                                       Int?
  supplierId                                              Int?
  form_id                                                 Int?
  form_data                                               Json?
  form_version                                            Int?
  process_id                                              Int?
  cost_center                                             String?              @db.VarChar(100)
  purchase_company_id                                     Int?
  invoice_number                                          String?              @db.VarChar(255)
  supplier_id                                             Int?
  AssetAssignment                                         AssetAssignment[]
  asset_components_asset_components_childAssetIdToassets  AssetComponent[]     @relation("asset_components_childAssetIdToassets")
  asset_components_asset_components_parentAssetIdToassets AssetComponent[]     @relation("asset_components_parentAssetIdToassets")
  AssetCustomValue                                        AssetCustomValue[]
  AssetDocument                                           AssetDocument[]
  AssetFieldValue                                         AssetFieldValue[]
  AssetImage                                              AssetImage[]
  AssetLicense                                            AssetLicense[]
  AssetStatusHistory                                      AssetStatusHistory[]
  AssetChangeHistory                                      AssetChangeHistory[] @relation("AssetChangeHistory")
  AssetTransfer                                           AssetTransfer[]
  users_assets_assignedUserIdTousers                      User?                @relation("assets_assignedUserIdTousers", fields: [assignedUserId], references: [documentNumber])
  AssetCategory                                           AssetCategory        @relation(fields: [categoryId], references: [id])
  companies_assets_companyIdTocompanies                   Company?             @relation("assets_companyIdTocompanies", fields: [companyId], references: [id])
  users_assets_createdByIdTousers                         User                 @relation("assets_createdByIdTousers", fields: [createdById], references: [documentNumber])
  AssetGroup                                              AssetGroup           @relation(fields: [groupId], references: [id])
  Headquarters                                            Headquarters?        @relation(fields: [headquartersId], references: [id])
  AssetModel                                              AssetModel?          @relation(fields: [modelId], references: [id])
  companies_assets_purchaseCompanyIdTocompanies           Company?             @relation("assets_purchaseCompanyIdTocompanies", fields: [purchaseCompanyId], references: [id])
  companies_assets_purchasedByCompanyIdTocompanies        Company?             @relation("assets_purchasedByCompanyIdTocompanies", fields: [purchasedByCompanyId], references: [id])
  AssetType                                               AssetType?           @relation(fields: [typeId], references: [id])
  users_assets_updatedByIdTousers                         User?                @relation("assets_updatedByIdTousers", fields: [updatedById], references: [documentNumber])
  users_assets_deletedByTousers                           User?                @relation("assets_deletedByTousers", fields: [deletedBy], references: [documentNumber], onUpdate: NoAction, map: "fk_assets_deletedBy")
  Form                                                    Form?                @relation(fields: [form_id], references: [id], onUpdate: NoAction, map: "fk_assets_form")
  Process                                                 Process?             @relation(fields: [process_id], references: [id], onUpdate: NoAction, map: "fk_assets_process")
