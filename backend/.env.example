# Database Configuration
DATABASE_URL="mysql://username:password@localhost:3306/itdimenzion_db"

# JWT Configuration (generate strong random values for production)
JWT_SECRET="CHANGE_ME_use_a_random_32_char_string"
JWT_EXPIRES_IN="24h"
JWT_REFRESH_SECRET="CHANGE_ME_use_another_random_32_char_string"

# Server Configuration
NODE_ENV="development"
PORT=4701
API_PREFIX="/api"

# CORS Configuration
FRONTEND_URL="http://localhost:3701"
ALLOWED_ORIGINS="http://localhost:3701,http://127.0.0.1:3701"

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Session Configuration
SESSION_SECRET="CHANGE_ME_use_another_random_string"
SESSION_COOKIE_MAX_AGE=86400000

# Security Configuration
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_TIME=1800000

# Default Admin Password (used by init-super-admin and create-test-users scripts)
DEFAULT_ADMIN_PASSWORD="CHANGE_ME_strong_password"

# Cloudinary (producción - Vercel/Render)
# Obtener credenciales en https://cloudinary.com
# CLOUDINARY_CLOUD_NAME="tu-cloud"
# CLOUDINARY_API_KEY="tu-key"
# CLOUDINARY_API_SECRET="tu-secret"

# ---- Variables para PRODUCCIÓN (Render + TiDB + Vercel) ----
# NODE_ENV=production
# PORT=10000
# DATABASE_URL=mysql://user:pass@host:4000/database?sslaccept=strict
# FRONTEND_URL=https://[tu-app].vercel.app
# ALLOWED_ORIGINS=https://[tu-app].vercel.app
